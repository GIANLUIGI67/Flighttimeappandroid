<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/iosBackground"
    android:padding="12dp">

    <ImageButton
        android:id="@+id/layoverInfoCategoryBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/training_back_button"
        android:src="@drawable/ic_back"
        app:tint="@color/iosText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/layoverInfoCategoryTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/cl_layover_info_categories"
        android:textColor="@color/iosText"
        android:textStyle="bold"
        android:textSize="18sp"
        app:layout_constraintTop_toTopOf="@id/layoverInfoCategoryBack"
        app:layout_constraintBottom_toBottomOf="@id/layoverInfoCategoryBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/layoverInfoCategoryCity"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/my_layover_info_city_format"
        android:textColor="@color/iosHint"
        android:textSize="14sp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/layoverInfoCategoryBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/layoverInfoEmptyText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/cl_layover_info_empty"
        android:textColor="@color/iosHint"
        android:textSize="14sp"
        android:visibility="gone"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/layoverInfoCategoryCity"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/layoverInfoItemsRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/layoverInfoCategoryCity"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layoverInfoAddBtn" />

    <Button
        android:id="@+id/layoverInfoAddBtn"
        style="@style/Widget.FlightTimeApp.TrainingButton.Blue"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="@string/cl_layover_info_add_button"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/layoverInfoItemsRecycler"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
