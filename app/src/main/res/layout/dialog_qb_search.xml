<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/iosBackground"
    android:orientation="vertical"
    android:padding="16dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/qbSearchTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/training_search_title"
            android:textColor="@color/iosText"
            android:textStyle="bold"
            android:textSize="16sp" />

        <ImageButton
            android:id="@+id/qbSearchClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:background="@android:color/transparent"
            android:contentDescription="@string/training_back_button"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/iosText" />
    </RelativeLayout>

    <EditText
        android:id="@+id/qbSearchInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_ios_field"
        android:hint="@string/training_search_placeholder"
        android:importantForAutofill="no"
        android:inputType="text"
        android:textColor="@color/iosText"
        android:textColorHint="@color/iosHint" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="@color/iosCardBg"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp">

        <ListView
            android:id="@+id/qbSearchList"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:dividerHeight="1dp"
            android:divider="@color/iosCardStroke" />
    </androidx.cardview.widget.CardView>
</LinearLayout>
