<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/iosBackground"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/bannerText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_ios_row_16"
            android:padding="12dp"
            android:textColor="@color/iosText"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/crewTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/crew_layover_title"
            android:textColor="@color/iosText"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/bannerText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/crewUnderConstruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cl_under_construction"
            android:textColor="@color/iosRed"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/crewTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/onlineNearbyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cl_online_nearby_default"
            android:textColor="@color/iosHint"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/crewUnderConstruction"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/navButtons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/onlineNearbyText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/nearMeBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/iosCardBg"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/iosCardStroke">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_location"
                        android:contentDescription="@string/cl_near_me"
                        app:tint="@color/iosIcon" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/cl_near_me"
                        android:textColor="@color/iosText"
                        android:textStyle="bold"
                        android:textSize="16sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="12dp"
                android:layout_height="0dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/settingsBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/iosCardBg"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/iosCardStroke">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_settings"
                        android:contentDescription="@string/settings_button"
                        app:tint="@color/iosIcon" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/settings_button"
                        android:textColor="@color/iosText"
                        android:textStyle="bold"
                        android:textSize="16sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/myLayoverInfoBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="@color/iosCardBg"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/iosCardStroke"
            app:layout_constraintTop_toBottomOf="@id/navButtons"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_settings"
                    android:contentDescription="@string/my_layover_info_title"
                    app:tint="@color/iosIcon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/my_layover_info_title"
                    android:textColor="@color/iosText"
                    android:textStyle="bold"
                    android:textSize="16sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/communityCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/iosCardBg"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/iosCardStroke"
            app:layout_constraintTop_toBottomOf="@id/myLayoverInfoBtn"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cl_community_dev_title"
                    android:textColor="@color/iosText"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cl_community_share_hint"
                    android:textColor="@color/iosHint"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/communityProfileWarning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cl_profile_required_warning"
                    android:textColor="@color/iosRed"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginTop="6dp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/shareBtn"
                    style="@style/Widget.FlightTimeApp.TrainingButton.Blue"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginTop="2dp"
                    android:text="@string/cl_share_button"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:paddingHorizontal="16dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/donateBtn"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_ios_row_16"
            android:text="@string/cl_donate_button"
            android:textColor="@color/iosText"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/communityCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
