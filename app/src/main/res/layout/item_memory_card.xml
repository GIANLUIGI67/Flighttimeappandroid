<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="@color/iosCardBg"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/memoryItemTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A320 EMER DESCENT"
            android:textColor="@color/iosRed"
            android:textStyle="bold"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btnReadMemory"
                style="@style/Widget.FlightTimeApp.TrainingButton.Gray"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:textSize="12sp"
                android:text="@string/training_read_memory" />

            <Space
                android:layout_width="12dp"
                android:layout_height="0dp" />

            <Button
                android:id="@+id/btnReadProcedure"
                style="@style/Widget.FlightTimeApp.TrainingButton.Gray"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:textSize="12sp"
                android:text="@string/training_read_procedure" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btnPlayMemory"
                style="@style/Widget.FlightTimeApp.TrainingButton.Blue"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:textSize="12sp"
                android:text="@string/training_play_memory" />

            <Space
                android:layout_width="12dp"
                android:layout_height="0dp" />

            <Button
                android:id="@+id/btnPlayProcedure"
                style="@style/Widget.FlightTimeApp.TrainingButton.Blue"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:textSize="12sp"
                android:text="@string/training_play_procedure" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btnLoopMemory"
                style="@style/Widget.FlightTimeApp.TrainingButton.Gray"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:textSize="12sp"
                android:text="@string/training_loop_memory" />

            <Space
                android:layout_width="12dp"
                android:layout_height="0dp" />

            <Button
                android:id="@+id/btnLoopProcedure"
                style="@style/Widget.FlightTimeApp.TrainingButton.Gray"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:textSize="12sp"
                android:text="@string/training_loop_procedure" />
        </LinearLayout>

        <Button
            android:id="@+id/btnStopSingle"
            style="@style/Widget.FlightTimeApp.TrainingButton.Gray"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:textSize="12sp"
            android:text="@string/training_stop" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
