<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_ios_row_12"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/layoverInfoTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Title"
            android:textColor="@color/iosText"
            android:textStyle="bold"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/layoverInfoLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Location"
            android:textColor="@color/iosHint"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/layoverInfoDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Details"
            android:textColor="@color/iosHint"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/layoverInfoEdit"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="10dp"
            android:contentDescription="@string/cl_layover_info_edit"
            android:src="@android:drawable/ic_menu_edit"
            android:tint="@color/iosBlue" />

        <ImageView
            android:id="@+id/layoverInfoDelete"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@string/cl_layover_info_delete"
            android:src="@drawable/ic_delete"
            android:tint="@color/iosRed" />
    </LinearLayout>

</LinearLayout>
