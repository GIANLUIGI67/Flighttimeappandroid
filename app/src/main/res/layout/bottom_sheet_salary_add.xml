<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/iosBackground"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/addFlight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp"
        android:text="@string/salary_add_menu_flight"
        android:textColor="@color/iosText"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/addOvertime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp"
        android:text="@string/salary_add_menu_overtime"
        android:textColor="@color/iosText"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/addLayoverDomestic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp"
        android:text="@string/salary_add_menu_layover_domestic"
        android:textColor="@color/iosText"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/addLayoverInternational"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp"
        android:text="@string/salary_add_menu_layover_international"
        android:textColor="@color/iosText"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>
