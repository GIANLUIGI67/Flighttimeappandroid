<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/iosBackground"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <TextView
        android:id="@+id/lockedTitleTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/salary_calculator_title"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="@color/iosText"
        android:layout_marginBottom="24dp" />

    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@android:drawable/ic_lock_lock"
        app:tint="@color/iosHint"
        android:contentDescription="@string/salary_locked_title" />

    <TextView
        android:id="@+id/lockedTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/salary_locked_title"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="@color/iosText"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/lockedMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/salary_locked_message"
        android:textSize="13sp"
        android:textColor="@color/iosHint"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textAlignment="center"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp" />

    <Button
        android:id="@+id/lockedUnlockButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/unlock_pro_button"
        android:layout_marginTop="16dp" />

</LinearLayout>
