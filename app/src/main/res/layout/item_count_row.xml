<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="6dp">

    <TextView
        android:id="@+id/countLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/salary_month_duty_count"
        android:textColor="@color/iosText"
        android:textSize="15sp"
        tools:text="Duty: 0" />

    <LinearLayout
        android:id="@+id/countPill"
        android:layout_width="80dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_ios_pill_light"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/countMinus"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/minus"
            android:textColor="@color/iosHint"
            android:textSize="18sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/iosCardStroke" />

        <TextView
            android:id="@+id/countPlus"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/plus"
            android:textColor="@color/iosText"
            android:textSize="18sp" />
    </LinearLayout>
</LinearLayout>
