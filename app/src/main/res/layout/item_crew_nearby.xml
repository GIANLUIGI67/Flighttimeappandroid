<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/crewPhoto"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_ios_pill_light"
        android:contentDescription="@string/cl_profile_photo" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/crewName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/iosText"
            android:textStyle="bold"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/crewSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/iosHint"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/crewDistance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/iosBlue"
        android:textStyle="bold"
        android:textSize="12sp" />

</LinearLayout>
