<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/crewPhoto"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_ios_circle"
        android:clipToOutline="true"
        android:scaleType="centerCrop"
        android:contentDescription="@string/cl_profile_photo" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/crewName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/iosText"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/crewOnlineChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_online_chip"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="@string/cl_online_chip"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/crewSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/iosHint"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/crewBio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/iosText"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:visibility="gone" />
    </LinearLayout>

    <ImageView
        android:id="@+id/crewChevron"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_chevron_right"
        android:contentDescription="@string/cl_open_chat"
        app:tint="@color/iosHint" />

</LinearLayout>
