<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_ios_row_12"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp">

    <ImageView
        android:id="@+id/layoverCategoryIcon"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:contentDescription="@string/cl_layover_info_categories"
        android:src="@drawable/ic_location"
        android:tint="@color/iosIcon" />

    <TextView
        android:id="@+id/layoverCategoryTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_weight="1"
        android:text="@string/cl_layover_info_categories"
        android:textColor="@color/iosText"
        android:textStyle="bold"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/layoverCategoryCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_ios_pill_light"
        android:gravity="center"
        android:minWidth="24dp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:text="0"
        android:textColor="@color/iosHint"
        android:textSize="12sp"
        android:visibility="gone" />

    <ImageView
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_chevron_right"
        android:tint="@color/iosChevron" />

</LinearLayout>
