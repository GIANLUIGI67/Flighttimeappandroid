<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/iosBackground"
    android:padding="12dp"
    android:fitsSystemWindows="true">

    <ImageButton
        android:id="@+id/chatBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/training_back_button"
        android:src="@drawable/ic_back"
        app:tint="@color/iosText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/chatTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/iosText"
        android:textStyle="bold"
        android:textSize="18sp"
        app:layout_constraintTop_toTopOf="@id/chatBack"
        app:layout_constraintBottom_toBottomOf="@id/chatBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/chatDeleteBtn"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/cl_clear_chat"
        android:src="@drawable/ic_delete"
        app:tint="@color/iosHint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/chatBack"
        app:layout_constraintBottom_toBottomOf="@id/chatBack" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/chatBack"
        app:layout_constraintBottom_toTopOf="@id/chatInputRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/chatInputRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/chatPhotoBtn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_ios_row_12"
            android:contentDescription="@string/cl_photo_section"
            android:src="@android:drawable/ic_menu_camera"
            app:tint="@color/iosText" />

        <TextView
            android:id="@+id/chatPhotoExpiryBtn"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_ios_btn_blue"
            android:backgroundTint="@null"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:minWidth="56dp"
            android:text="∞"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="12sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:textAllCaps="false" />

        <EditText
            android:id="@+id/chatInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_ios_field"
            android:padding="10dp"
            android:hint="@string/cl_message_hint"
            android:textColor="@color/iosText"
            android:textColorHint="@color/iosHint" />

        <Button
            android:id="@+id/chatSend"
            style="@style/Widget.FlightTimeApp.TrainingButton.Blue"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:text="@string/cl_send"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
