<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/iosBackground"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="18dp">

        <TextView
            android:id="@+id/bandsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/salary_settings_block_hour_bands_title"
            android:textColor="@color/iosText"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/bandsCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="6dp"
            android:paddingVertical="6dp"
            android:clickable="true"
            android:focusable="true"
            android:text="@string/salary_settings_cancel"
            android:textColor="@color/iosBlue"
            android:textSize="15sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/bandsSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="6dp"
            android:paddingVertical="6dp"
            android:clickable="true"
            android:focusable="true"
            android:text="@string/salary_settings_save"
            android:textColor="@color/iosBlue"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bandsCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/iosCardBg"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/iosCardStroke"
            app:strokeWidth="0.5dp"
            app:layout_constraintTop_toBottomOf="@id/bandsTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:id="@+id/bandsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/bandsAdd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/salary_settings_add_band"
            android:textColor="@color/iosBlue"
            android:textSize="15sp"
            app:layout_constraintTop_toBottomOf="@id/bandsCard"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/bandsExample"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/salary_settings_bands_example"
            android:textColor="@color/iosHint"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/bandsAdd"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
