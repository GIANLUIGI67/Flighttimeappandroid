<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:background="@drawable/bg_ios_row_16"
    android:padding="10dp">

    <ImageView
        android:id="@+id/mosaicPhoto"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_ios_row_16"
        android:clipToOutline="true"
        android:scaleType="centerCrop"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/mosaicOnlineDot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/unread_dot"
        app:layout_constraintTop_toTopOf="@id/mosaicPhoto"
        app:layout_constraintEnd_toEndOf="@id/mosaicPhoto"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="6dp" />

    <TextView
        android:id="@+id/mosaicName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/iosText"
        android:textStyle="bold"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/mosaicPhoto"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/mosaicSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/iosHint"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/mosaicName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/mosaicDistance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/iosBlue"
        android:textStyle="bold"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/mosaicSubtitle"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/mosaicOpenChat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/iosHint"
        android:textSize="12sp"
        android:text="@string/cl_open_chat"
        app:layout_constraintTop_toBottomOf="@id/mosaicDistance"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
